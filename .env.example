# DeepSeek 大模型配置（命理分析使用）
# 必填：API Key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选：自定义 Base URL（默认官方端点 https://api.deepseek.com）
# 兼容任何 OpenAI 风格的网关，例如 https://api.deepseek.com 或 https://your-proxy.com
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选：模型名（默认 deepseek-chat；推理模型可填 deepseek-reasoner 或 deepseek-v4-pro）
DEEPSEEK_MODEL=deepseek-chat

# 可选：是否启用思考链（reasoning）。默认空；当模型名匹配 v4-pro/reasoner 时会自动启用。
# 设为 1 可强制开启 thinking + reasoning_effort=high。
DEEPSEEK_THINKING=
